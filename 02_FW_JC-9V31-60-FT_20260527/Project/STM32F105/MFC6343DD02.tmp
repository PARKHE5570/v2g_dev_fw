//		UART1_PutDec(1, (u16)SECC_Msg.SECC_Status_1.seccVersionMinor); 
//		UART1_PutChar('.'); 
//		UART1_PutDec(1, (u16)SECC_Msg.SECC_Status_1.seccVersionPatch);
//		
//	    if     (device_id == 1) UART1_PutStr(" CHANNEL_ID:1");
//        else if(device_id == 2) UART1_PutStr(" CHANNEL_ID:2");
		
