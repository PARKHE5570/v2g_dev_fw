void Send_Uart_Terminal_default(void)
{
//	if     (device_id == 1) UART1_PutStr("\r CHANNEL_ID:1");
//	else if(device_id == 2) UART1_PutStr("\r CHANNEL_ID:2");
//
//    UART1_PutStr(" Seq: "); UART1_PutDec(4, sequence_step);

	UART1_PutStr(" \r CP:");
	if(SECC_Msg.SECC_Status_2.cpVoltage_12 < 0) {UART1_PutStr("-");UART1_PutDec(3, ~(SECC_Msg.SECC_Status_2.cpVoltage_12)+1);} // shortÇü 
	else                                        {UART1_PutStr(" ");UART1_PutDec(3, (u16)SECC_Msg.SECC_Status_2.cpVoltage_12);}
//	if     (SECC_Msg.SECC_Status_2.CP_Status_0.bit.cpOscillator == TRUE) {UART1_PutStr(" PWM:");  UART1_PutStr("  ON"); }
//	else if(SECC_Msg.SECC_Status_2.CP_Status_0.bit.cpOscillator == FALSE){UART1_PutStr(" PWM:");  UART1_PutStr(" OFF"); }
	
	UART1_PutStr(" COUPLER:"); 
	if   (coupler_temperature_P == 1) UART1_PutStr("OPEN"); 
    else                              UART1_PutDec(4, (uint16_t)coupler_temperature_P);
//	UART1_PutStr(" [ˇÉ] ");
	
	if(Digital_input.bit.I_RY1) UART1_PutStr(" Relay1: ON"); 
	else                        UART1_PutStr(" Relay1:OFF"); 
	if(Digital_input.bit.I_RY2) UART1_PutStr(" Relay2: ON");
	else                        UART1_PutStr(" Relay2:OFF");
	if(Digital_input_buffer4.bit.I_LIMIT == 1) UART1_PutStr(" FUSE:OPEN"); 
	else                                       UART1_PutStr(" FUSE: OK!"); 

	UART1_PutStr(" MODULE:");
	if(module_on_off == 1) UART1_PutStr(" ON");
	else                   UART1_PutStr("OFF"); 
						
	UART1_PutStr(" Vref:"); UART1_PutDec(3, (u16)Vout_ref_temp);
    UART1_PutStr(" Vout:"); UART1_PutDec(3, (u16)Vout);
    UART1_PutStr(" Iref:"); UART1_PutDec(3, (u16)Iout_ref_temp);
	UART1_PutStr(" Iout:"); UART1_PutDec(3, (u16)Iout_Module);
//    UART1_PutStr(" "); // ±¸şĐ
    UART1_PutStr(" M1:"); UART1_PutDec(3, (u16)module_info[0].ufVout.fValue); UART1_PutStr("[V]");
	UART1_PutStr(" M2:"); UART1_PutDec(3, (u16)module_info[1].ufVout.fValue); UART1_PutStr("[V]");
	UART1_PutStr(" M3:"); UART1_PutDec(3, (u16)module_info[2].ufVout.fValue); UART1_PutStr("[V]");
	UART1_PutStr(" M4:"); UART1_PutDec(3, (u16)module_info[3].ufVout.fValue); UART1_PutStr("[V]");
	UART1_PutStr(" M5:"); UART1_PutDec(3, (u16)module_info[4].ufVout.fValue); UART1_PutStr("[V]"); //¸đµâŔĚ 4°ł¸é ÁÖĽ®Ăł¸®
//	UART1_PutStr(" "); // ±¸şĐ
	UART1_PutStr(" M1:"); UART1_PutDec(2, (u16)module_info[0].ufIout.fValue); UART1_PutStr("[A]");
	UART1_PutStr(" M2:"); UART1_PutDec(2, (u16)module_info[1].ufIout.fValue); UART1_PutStr("[A]");
	UART1_PutStr(" M3:"); UART1_PutDec(2, (u16)module_info[2].ufIout.fValue); UART1_PutStr("[A]");
	UART1_PutStr(" M4:"); UART1_PutDec(2, (u16)module_info[3].ufIout.fValue); UART1_PutStr("[A]");
	UART1_PutStr(" M5:"); UART1_PutDec(2, (u16)module_info[4].ufIout.fValue); UART1_PutStr("[A]"); //¸đµâŔĚ 4°ł¸é ÁÖĽ®Ăł¸®
//	if(module1_rx_fault_flag) UART1_PutStr(" M1: CAN_RX_failure ");
//	if(module2_rx_fault_flag) UART1_PutStr(" M2: CAN_RX_failure ");
//	if(module3_rx_fault_flag) UART1_PutStr(" M3: CAN_RX_failure ");
//	if(module4_rx_fault_flag) UART1_PutStr(" M4: CAN_RX_failure ");
//	if(module5_rx_fault_flag) UART1_PutStr(" M5: CAN_RX_failure "); //¸đµâŔĚ 4°ł¸é ÁÖĽ®Ăł¸®
//	UART1_PutStr(" "); // ±¸şĐ
	if     (SECC_Msg.SECC_Status_1.seccStatusCode == Idle_Wait                           ) UART1_PutStr(" Idle_Wait              ");                              
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == Idle                                ) UART1_PutStr(" Idle                   ");                           
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == Ready                               ) UART1_PutStr(" Ready                  "); 
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == Low_Level_Comm                      ) UART1_PutStr(" Low_Level_Comm         ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == High_Level_Comm                     ) UART1_PutStr(" High_Level_Comm        "); 
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == Authorization_ContractAuthentication) UART1_PutStr(" Authorization          ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == ChargeParameterDiscovery            ) UART1_PutStr(" ParameterDiscovery     ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == CableCheck                          ) UART1_PutStr(" CableCheck             ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == PreCharge                           ) UART1_PutStr(" PreCharge              ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == Charging                            ) UART1_PutStr(" Charging               ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == Renegotiation                       ) UART1_PutStr(" Renegotiation          ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == EV_Init_Stop_Charging               ) UART1_PutStr(" EV_Init_Stop_Charging  ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == EVSE_Init_Stop_Charging             ) UART1_PutStr(" EVSE_Init_Stop_Charging"); 
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == Terminate                           ) UART1_PutStr(" Terminate              ");    
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == CertificateInstallation             ) UART1_PutStr(" CertificateInstallation");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == CertificatedUpdate                  ) UART1_PutStr(" CertificatedUpdate     ");
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == SECC_ERROR                          ) UART1_PutStr(" SECC_ERROR             ");
//	UART1_PutStr(" "); // ±¸şĐ
	if     (SECC_Msg.SECC_Status_1.seccErrorCode == SECC_NO_ERROR                          ) UART1_PutStr(" SECC_NO_ERROR                  ");
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED                                 ) UART1_PutStr(" FAILED                         ");
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_SequenceError                   ) UART1_PutStr(" SequenceError                  ");
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_ServiceIDInvalid                ) UART1_PutStr(" ServiceIDInvalid               ");
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_UnknownSession                  ) UART1_PutStr(" UnknownSession                 ");  
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_ServiceSelectionInvalid         ) UART1_PutStr(" ServiceSelectionInvalid        "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_PaymentSelectionInvalid         ) UART1_PutStr(" PaymentSelectionInvalid        ");  
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_CertificateExpired              ) UART1_PutStr(" CertificateExpired             "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_SignatureError                  ) UART1_PutStr(" SignatureError                 "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_NoCertificateAvailable          ) UART1_PutStr(" NoCertificateAvailable         "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_CerChainError                   ) UART1_PutStr(" CerChainError                  "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_ChallengeInvalid                ) UART1_PutStr(" ChallengeInvalid               "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_ContractCanceled                ) UART1_PutStr(" ContractCanceled               "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_WrongChargeParameter            ) UART1_PutStr(" WrongChargeParameter           "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_PowerDeliveryNotApplied         ) UART1_PutStr(" PowerDeliveryNotApplied        "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_TariffSelectionInvalid          ) UART1_PutStr(" TariffSelectionInvalid         "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_ChargingProfileInvalid          ) UART1_PutStr(" ChargingProfileInvalid         "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_MeteringSignatureNotValid       ) UART1_PutStr(" MeteringSignatureNotValid      "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_NoChargeServiceSelected         ) UART1_PutStr(" NoChargeServiceSelected        "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_WrongEnergyTransferMode         ) UART1_PutStr(" WrongEnergyTransferMode        "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_ContactorError                  ) UART1_PutStr(" ContactorError                 "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_CertificateNotAllowedAtThisEVSE ) UART1_PutStr(" CertificateNotAllowedAtThisEVSE"); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_CertificateRevoked              ) UART1_PutStr(" CertificateRevoked             "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_NoNegotiation                   ) UART1_PutStr(" NoNegotiation                  "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == TIMEOUT_CommunicationSetup             ) UART1_PutStr(" TIMEOUT_CommunicationSetup     "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == TIMEOUT_Sequence                       ) UART1_PutStr(" TIMEOUT_Sequence               "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == TIMEOUT_NotificationMaxDelay           ) UART1_PutStr(" TIMEOUT_NotificationMaxDelay   "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == TIMEOUT_WeldingDetection               ) UART1_PutStr(" TIMEOUT_WeldingDetection       "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_WrongCPLevel                    ) UART1_PutStr(" FAILED_WrongCPLevel            "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_ProximityError                  ) UART1_PutStr(" FAILED_ProximityError          "); 
	else if(SECC_Msg.SECC_Status_1.seccErrorCode == FAILED_HLCError                        ) UART1_PutStr(" FAILED_HLCError                "); 
