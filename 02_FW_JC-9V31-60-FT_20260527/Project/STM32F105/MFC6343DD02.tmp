        UART1_PutStr("\r\n   Ćßżţľî ľ÷µĄŔĚĆ® ¸đµĺ ˝ÇÇŕ Ŕüżˇ HMIŔÇ ĂćŔü±â(ŔŔżë) ÇÁ·Î±×·ĄŔ» Áľ·áÇĎÁö ľĘľŇ´Ů¸é ŔŔżë ÇÁ·Î±×·Ą Áľ·á ČÄ ąÝµĺ˝Ă ľ÷µĄŔĚĆ® ĆÄŔĎŔ» ŔüĽŰÇŘľßÇŐ´Ď´Ů. \r\n");
		UART1_PutStr("\r\n   ľ÷µĄŔĚĆ® ĆÄŔĎŔ» ŔüĽŰÇĎÁö ľĘŔ¸¸é ¸ŢŔÎ ÇÁ·Î±×·ĄŔ¸·Î şą±¸µÇÁö ľĘŔ» Ľö ŔÖ˝Ŕ´Ď´Ů. \r\n"); 
		UART1_PutStr("\r\n   1şĐ ŔĚ»ó ŔĚ »óĹÂ°ˇ ÁöĽÓµÇ¸é ÄÁĆ®·Ńş¸µĺŔÇ ¸®ĽÂ ąöĆ°Ŕ» ´­·ŻĽ­ şÎĆ® ÇÁ·Î±×·ĄŔĚ Áľ·áµÉ ¶§±îÁö(1şĐ) ±â´Ů¸ł´Ď´Ů. ¶Ç´Â şÎĆ® ÇÁ·Î±×·Ą°ú ¸ŢŔÎ ÇÁ·Î±×·ĄŔ» ´Ů˝Ă ´Ůżî·Îµĺ ÇĎĽĽżä. \n ");
        UART1_PutStr("\r\n ********************************************************************************************************** \r\n");
