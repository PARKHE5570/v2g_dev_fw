													UART1_PutStr("\r\n ¸¶Áö¸· ľ÷µĄŔĚĆ® ŔĎŔÚ  : "); UART1_PutDec(2, (u16)last_update_year); UART1_PutChar('.'); UART1_PutDec(2, (u16)last_update_month); UART1_PutChar('.'); UART1_PutDec(2, (u16)last_update_day);	
