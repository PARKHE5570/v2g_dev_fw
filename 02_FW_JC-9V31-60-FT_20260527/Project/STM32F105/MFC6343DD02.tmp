	else                                        {UART1_PutStr(" ");UART1_PutDec(3, (u16)SECC_Msg.SECC_Status_2.cpVoltage_12);}
																				
	if     (SECC_Msg.SECC_Status_2.CP_Status_0.bit.cpOscillator == TRUE) {UART1_PutStr(" PWM:");  UART1_PutStr("  ON"); }
	else if(SECC_Msg.SECC_Status_2.CP_Status_0.bit.cpOscillator == FALSE){UART1_PutStr(" PWM:");  UART1_PutStr(" OFF"); }

	UART1_PutStr("  80%±îÁö ł˛Ŕş˝Ă°Ł: "); UART1_PutDec(3, (u16)(SECC_Msg.SECC_EV_SoC_Related_Parameters.remainingTimeToBulkSOC_67 * 0.166666666F)); UART1_PutStr("şĐ"); // 1/6 = 0.166666666F
	UART1_PutStr(" 100%±îÁö ł˛Ŕş˝Ă°Ł: "); UART1_PutDec(3, (u16)(SECC_Msg.SECC_EV_SoC_Related_Parameters.remainingTimeToFullSOC_45 * 0.166666666F)); UART1_PutStr("şĐ"); // ex) 198 -> 198/6 = 33min	
	
	targetvoltage  = (UINT16)((float)SECC_Msg.SECC_EV_TargetVoltage_Current.targetVoltage_01 * 0.1F);
	current_demand = (UINT16)((float)SECC_Msg.SECC_EV_TargetVoltage_Current.targetCurrent_23 * 0.1F);
	
	UART1_PutStr(" ¸ńÇĄŔüľĐ: "); UART1_PutDec(3, targetvoltage);  UART1_PutStr(" ÇöŔçŔüľĐ: "); UART1_PutDec(3, (u16)Vout);
	UART1_PutStr(" żäĂ»Ŕü·ů: "); UART1_PutDec(3, current_demand); UART1_PutStr(" ÇöŔçŔü·ů: "); UART1_PutDec(3, (u16)Iout_Module);

	UART1_PutStr("ĂćŔü Ŕü·Â : ");  
	if     (Vout * Iout_Module * 0.001F >= 100) {                   UART1_PutDec(3, (u16)(Vout * Iout_Module * 0.001F));}
	else if(Vout * Iout_Module * 0.001F >=  10) {UART1_PutStr(" "); UART1_PutDec(2, (u16)(Vout * Iout_Module * 0.001F));}
	else if(Vout * Iout_Module * 0.001F >=   0) {UART1_PutStr("  ");UART1_PutDec(1, (u16)(Vout * Iout_Module * 0.001F));}
	UART1_PutStr(" [kW], ");
	
	UART1_PutStr("ĂćŔü Ŕü·Â·® : ");
	if     (dc_electric_energy >= 100) {                    UART1_PutDec(3, (u16)(dc_electric_energy));}
	else if(dc_electric_energy >=  10) {UART1_PutStr(" ");  UART1_PutDec(2, (u16)(dc_electric_energy));}
	else if(dc_electric_energy >=   0) {UART1_PutStr("  "); UART1_PutDec(1, (u16)(dc_electric_energy));}
	UART1_PutChar('.'); 
	UART1_PutDec(1, (u16)(dc_electric_energy * 100 * 0.1F));
	UART1_PutDec(1, (u16)(dc_electric_energy * 100));
	UART1_PutStr(" [kWh] ");
 
	if(SECC_Msg.SECC_Status_1.seccStatusCode == Charging)
	{
		elapsed_time++; // 100ms timer
		elapsed_time_s = elapsed_time * 0.1F; // sec timer

		minute = (uint16_t)(elapsed_time_s * 0.0166666667);
		hour   = (uint16_t)(minute * 0.0166666667);
		minute = (uint16_t)(minute % 60);
		second = (uint16_t)((u16)elapsed_time_s % 60);
	}
	UART1_PutStr("ĂćŔü ˝Ă°Ł : "); UART1_PutDec(1, (u16)hour); UART1_PutStr(":"); UART1_PutDec(2, (u16)minute); UART1_PutStr(":"); UART1_PutDec(2, (u16)second); UART1_PutStr("."); UART1_PutDec(1, elapsed_time);
	
	UART1_PutStr(" ˝ĂŔŰ ąčĹÍ¸® : "); UART1_PutDec(2, start_SOC); UART1_PutStr("[%], ");
	UART1_PutStr(T_BOLD); UART1_PutStr(T_BrWHITE); UART1_PutStr(" ÇöŔç ąčĹÍ¸® : "); 
	
	if(test_timer1++ >= 2) 	{test_timer1 = 0; soc_blink ^= 1;}
	if(test_timer++ >= 1){SOC += 10; test_timer = 0;}
	if(SOC >= 100) SOC = 0;
	UART1_PutStr("[");
	if     (SOC >   0 && SOC <  10) {UART1_PutStr("\033[30;41m");if(soc_blink){UART1_PutStr("ˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("                  ");}else {                 UART1_PutStr("\033[0m");UART1_PutStr("                    "); }}
	else if(SOC >= 10 && SOC <  20) {UART1_PutStr("\033[30;41m");if(soc_blink){UART1_PutStr("ˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("                ");}else {UART1_PutStr("ˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("                  "); }}
	else if(SOC >= 20 && SOC <  30) {UART1_PutStr("\033[30;43m");if(soc_blink){UART1_PutStr("ˇŕˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("              ");}else {UART1_PutStr("ˇŕˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("                "); }}
	else if(SOC >= 30 && SOC <  40) {UART1_PutStr("\033[30;43m");if(soc_blink){UART1_PutStr("ˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("            ");}else {UART1_PutStr("ˇŕˇŕˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("              "); }}
	else if(SOC >= 40 && SOC <  50) {UART1_PutStr("\033[30;43m");if(soc_blink){UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("          ");}else {UART1_PutStr("ˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("            "); }}
	else if(SOC >= 50 && SOC <  60) {UART1_PutStr("\033[30;43m");if(soc_blink){UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("        ");}else {UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("          "); }}
	else if(SOC >= 60 && SOC <  70) {UART1_PutStr("\033[30;43m");if(soc_blink){UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("      ");}else {UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("        "); }}
	else if(SOC >= 70 && SOC <  80) {UART1_PutStr("\033[30;42m");if(soc_blink){UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("    ");}else {UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("      "); }}
	else if(SOC >= 80 && SOC <  90) {UART1_PutStr("\033[30;42m");if(soc_blink){UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("  ");}else {UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("    "); }}
	else if(SOC >= 90 && SOC < 100) {UART1_PutStr("\033[30;42m");if(soc_blink){UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m"); UART1_PutStr("");}else {UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕ");UART1_PutStr("\033[0m");UART1_PutStr("  "); }}
	else if(SOC >= 100)             {UART1_PutStr("\033[30;42m");              UART1_PutStr("ˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕˇŕ"); }
	else if(SOC == 0)               {UART1_PutStr("\033[0m"); UART1_PutStr("                    ");}
	
	UART1_PutStr("\033[0m");
	UART1_PutStr(T_BOLD);UART1_PutStr(T_BrWHITE);
	UART1_PutStr("] ");
	if     ((s16)SOC >= 100) {                   UART1_PutDec(3, (u16)SOC);}
	else if((s16)SOC >=  10) {UART1_PutStr(" "); UART1_PutDec(2, (u16)SOC);}
	else if((s16)SOC >=   0) {UART1_PutStr("  ");UART1_PutDec(1, (u16)SOC);}
	UART1_PutStr("[%] ");	
	UART1_PutStr(T_RESET);
	UART1_PutStr("\r ");	

}