	UART1_PutStr("\r ˝Ă˝şĹŰ ŔüĂĽ µżŔŰ ˝Ă°Ł : "); UART1_PutDec(3, (u16)g_day); UART1_PutStr(" [Day] ");UART1_PutDec(2, (u16)g_hour); UART1_PutStr(":"); UART1_PutDec(2, (u16)g_minute); UART1_PutStr(":"); UART1_PutDec(2, (u16)g_second);
	}
	else if(system_cmd == charging_status) Send_Uart_Terminal_default();
