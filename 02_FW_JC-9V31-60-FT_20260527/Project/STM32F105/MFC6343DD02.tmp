													UART1_PutStr("\r\n ĆÄżö ¸đµâ             : ŔÎÇÇĆÄżö(INFYPOWER)");
	if(!GPIO_ReadInputDataBit(GPIOE, GPIO_Pin_2))   UART1_PutStr("\r\n ş¸µĺ ÁˇĆŰÇÉ ĽłÁ¤ Á¤ş¸ : 1 (żŢÂĘ Ă¤łÎ) \r\n ");
