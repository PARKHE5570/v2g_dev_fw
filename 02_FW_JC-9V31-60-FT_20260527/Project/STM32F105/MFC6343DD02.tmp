	UART1_PutStr("[A]");
	
	UART1_PutStr(" M5:");
	if     (module_info[4].ufIout.fValue >=  10) {                  UART1_PutDec(2, (u16)module_info[4].ufIout.fValue);}
	else if(module_info[4].ufIout.fValue >=   0) {UART1_PutStr(" ");UART1_PutDec(1, (u16)module_info[4].ufIout.fValue);}	
	UART1_PutStr("[A] ");

	UART1_PutStr(" CP:"); 
	if(SECC_Msg.SECC_Status_2.cpVoltage_12 < 0) {UART1_PutStr("-");UART1_PutDec(3, ~(SECC_Msg.SECC_Status_2.cpVoltage_12)+1);} // shortÇü 
	else                                        {UART1_PutStr(" ");UART1_PutDec(3, (u16)SECC_Msg.SECC_Status_2.cpVoltage_12);}
					
	UART1_PutStr(" ");
	
	if     (SECC_Msg.SECC_Status_2.CP_Status_0.bit.cpOscillator == TRUE  && cpOscillator_old != TRUE) {UART1_PutStr(" PWM:");  UART1_PutStr("  ON"); }
	else if(SECC_Msg.SECC_Status_2.CP_Status_0.bit.cpOscillator == FALSE && cpOscillator_old != FALSE){UART1_PutStr(" PWM:");  UART1_PutStr(" OFF"); }
	
    cpOscillator_old = SECC_Msg.SECC_Status_2.CP_Status_0.bit.cpOscillator;


	if     (SECC_Msg.SECC_Status_1.seccStatusCode == Idle_Wait)                             
	{
		UART1_PutStr(" Idle_Wait              ");
	} 
	else if(SECC_Msg.SECC_Status_1.seccStatusCode == Idle                                 && seccStatusCode_old != Idle)                                  
	{
		UART1_PutStr(" Idle                   ");
